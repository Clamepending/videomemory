{
  "name": "@clamepending/videomemory",
  "version": "0.1.5",
  "description": "VideoMemory OpenClaw plugin, hook pack, and host onboarding CLI",
  "type": "module",
  "license": "UNLICENSED",
  "bin": {
    "videomemory-openclaw": "cli.mjs"
  },
  "openclaw": {
    "compat": {
      "pluginApi": ">=2026.2.2-0 <2027.0.0"
    },
    "extensions": [
      "./index.mjs"
    ],
    "hooks": [
      "./hooks/videomemory-startup"
    ]
  },
  "scripts": {
    "prepack": "node scripts/sync-bundled-scripts.mjs"
  },
  "files": [
    "README.md",
    "bundled",
    "cli.mjs",
    "hooks",
    "index.mjs",
    "openclaw.plugin.json",
    "skills",
    "src"
  ]
}
